# Copy to stack.env (do not commit stack.env). Portainer: set this as "Env file" for the stack.
#
# ---------- ENVIRONMENT ----------
# ENV_NAME=dev|stage|prod (optional, for your own tracking/logging)
ENV_NAME=prod

# ---------- DJANGO ----------
DJANGO_SETTINGS_MODULE=backend.settings_production
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False

# Comma-separated hosts (no scheme). Include your tunnel hostnames.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,mystock.trahey.net,mystock-api.trahey.net

# Comma-separated origins (include scheme). Used for CORS + CSRF trusted origins.
DJANGO_CORS_ALLOWED_ORIGINS=https://mystock.trahey.net
DJANGO_CSRF_TRUSTED_ORIGINS=https://mystock.trahey.net

# ---------- DATABASE (Postgres) ----------
POSTGRES_DB=mystock
POSTGRES_USER=mystock_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional: if you prefer DATABASE_URL style, keep it in sync with above.
DATABASE_URL=postgres://mystock_user:change-me@db:5432/mystock

# ---------- GOOGLE OAUTH (Frontend) ----------
# Vite build-time variables (baked into frontend build)
VITE_API_BASE_URL=https://mystock-api.trahey.net
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ---------- GOOGLE OAUTH (Backend) ----------
GOOGLE_OAUTH2_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH2_CLIENT_SECRET=change-me

